#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["utz[cli]"]
# ///
"""Force-create/move a version tag to HEAD, with status reporting."""

import json as json_mod
import tomllib
from pathlib import Path
from re import fullmatch, search

from utz import err
from utz.cli import arg, cmd, flag
from utz.process import check, line, lines, run, text


VERSION_RGX = r'\d+\.\d+\.\d+[a-zA-Z0-9._-]*'


def version_from_diff(commit: str = "HEAD") -> str | None:
    """Extract version from commit diff (pyproject.toml or package.json)."""
    for path in ["pyproject.toml", "package.json"]:
        diff_lines = lines('git', 'show', commit, '--', path, err_ok=True, log=None)
        if diff_lines:
            for ln in diff_lines:
                if ln.startswith('+') and 'version' in ln:
                    m = search(VERSION_RGX, ln)
                    if m:
                        return m.group(0)
    return None


def version_from_file() -> str | None:
    """Read version directly from project files."""
    pyproject = Path("pyproject.toml")
    if pyproject.exists():
        try:
            data = tomllib.loads(pyproject.read_text())
            version = data.get("project", {}).get("version")
            if version:
                return version
        except Exception:
            pass

    pkg_json = Path("package.json")
    if pkg_json.exists():
        try:
            data = json_mod.loads(pkg_json.read_text())
            version = data.get("version")
            if version:
                return version
        except Exception:
            pass

    return None


def detect_prefix(version: str) -> str:
    """Detect v-prefix convention from existing tags."""
    if check('git', 'rev-parse', f'v{version}', log=None):
        return "v"
    if check('git', 'rev-parse', version, log=None):
        return ""
    # Check convention from most recent semver tags
    tags = lines('git', 'tag', '--sort=-version:refname', err_ok=True, log=None) or []
    v_count = 0
    bare_count = 0
    for t in tags[:20]:
        if fullmatch(r'v\d+.*', t):
            v_count += 1
        elif fullmatch(r'\d+.*', t):
            bare_count += 1
    return "" if bare_count > v_count else "v"


def resolve_tag() -> str | None:
    """Determine version and tag name from commit message, diff, or project files."""
    # 1. Commit message matches version pattern
    msg = line('git', 'log', '-n1', '--format=%s', log=None)
    if msg and fullmatch(rf'v?{VERSION_RGX}', msg):
        err(f"tag from commit message: {msg}")
        return msg

    # 2. Version bump detected in commit diff
    version = version_from_diff()
    source = "commit diff" if version else None

    # 3. Version from project file
    if not version:
        version = version_from_file()
        source = "project file" if version else None

    if not version:
        return None

    prefix = detect_prefix(version)
    tag = f"{prefix}{version}"
    err(f"tag from {source}: {tag}")
    return tag


def report_tag(tag: str) -> bool:
    """Report tag status. Returns False if tag already at HEAD (no-op)."""
    head_sha = line('git', 'rev-parse', '--short', 'HEAD', log=None)
    old_sha = None

    if check('git', 'rev-parse', tag, log=None):
        old_sha = line('git', 'rev-parse', '--short', tag, log=None)
        if old_sha == head_sha:
            err(f"{tag}: already at {head_sha} (HEAD)")
            return False
        behind = line('git', 'rev-list', '--count', f'{tag}..HEAD', log=None)
        ahead = line('git', 'rev-list', '--count', f'HEAD..{tag}', log=None)
        err(f"{tag}: {old_sha} → {head_sha} (+{behind}/-{ahead} commits)")
    else:
        err(f"{tag}: (new) → {head_sha}")

    # Check remote tag status
    remote = line('git', 'rev-parse', '--abbrev-ref', '@{u}', err_ok=True, log=None)
    if remote:
        remote = remote.split('/')[0]
    if not remote:
        remotes = lines('git', 'remote', err_ok=True, log=None)
        remote = remotes[0] if remotes else None
    if remote:
        remote_lines = lines('git', 'ls-remote', '--tags', remote, f'refs/tags/{tag}', err_ok=True, log=None) or []
        if remote_lines:
            remote_sha = remote_lines[0].split('\t')[0]
            remote_short = remote_sha[:7]
            if old_sha and remote_short == old_sha:
                err(f"{tag}: on {remote} at {old_sha} (will need push)")
            elif remote_short == head_sha:
                err(f"{tag}: on {remote} already at {head_sha}")
            else:
                err(f"{tag}: on {remote} at {remote_short} (diverged, will need force push)")
        else:
            err(f"{tag}: not on {remote}")

    return True


def preserve_tag(tag: str, *refs: str, dry_run: bool = False):
    """Create or force-update a tag, preserving annotated tag messages."""
    _log = err if dry_run else None
    if check('git', 'rev-parse', tag, log=None):
        cat_lines = lines('git', 'cat-file', '-p', tag, err_ok=True, log=None) or []
        is_annotated = any(ln.startswith('tag ') for ln in cat_lines)
        if is_annotated:
            tag_msg = text('git', 'tag', '-l', '--format=%(contents)', tag, log=None) or ""
            run('git', 'tag', '-f', '-a', tag, '-m', tag_msg, *refs, log=_log, dry_run=dry_run)
        else:
            run('git', 'tag', '-f', tag, *refs, log=_log, dry_run=dry_run)
    else:
        run('git', 'tag', tag, *refs, log=_log, dry_run=dry_run)


@cmd()
@flag('-n', '--dry-run', help="Show what would happen without creating/moving the tag")
@arg('tag', required=False, default=None)
@arg('refs', nargs=-1)
def main(dry_run: bool, tag: str | None, refs: tuple[str, ...]):
    """Force-create/move a version tag to HEAD, with status reporting."""
    if not tag:
        tag = resolve_tag()
        if not tag:
            err("Usage: git tag-f [tag]")
            err("Could not determine version from commit message, diff, pyproject.toml, or package.json.")
            raise SystemExit(1)
    if not report_tag(tag):
        raise SystemExit(0)
    preserve_tag(tag, *refs, dry_run=dry_run)
    print(tag)


if __name__ == "__main__":
    main()
