#!/usr/bin/env bash
# Show `git status --short` for each worktree.
# Usage: git worktree-statuses [-l|--long]

long=
if [ "$1" = "-l" ] || [ "$1" = "--long" ]; then
    long=1; shift
fi

git worktree list --porcelain | while IFS= read -r line; do
    case "$line" in
        worktree\ *)
            wt="${line#worktree }"
            ;;
        branch\ *)
            branch="${line#branch refs/heads/}"
            ;;
        "")
            status="$(git -C "$wt" status --short 2>/dev/null)"
            if [ -n "$status" ]; then
                n="$(echo "$status" | wc -l | tr -d ' ')"
                printf "\033[1;33m%s\033[0m (%s) — %s change%s\n" "$wt" "$branch" "$n" "$([ "$n" != 1 ] && echo s)"
                if [ -n "$long" ]; then
                    echo "$status" | sed 's/^/  /'
                fi
            else
                printf "\033[1;32m%s\033[0m (%s) — clean\n" "$wt" "$branch"
            fi
            branch=
            ;;
    esac
done
