#!/usr/bin/env bash
# Show `git status` for each worktree, under a header per worktree.

git worktree list --porcelain | while IFS= read -r line; do
    case "$line" in
        worktree\ *)
            wt="${line#worktree }"
            ;;
        branch\ *)
            branch="${line#branch refs/heads/}"
            ;;
        "")
            printf "\033[1;34m%s\033[0m (%s)\n" "$wt" "$branch"
            git -C "$wt" status 2>/dev/null | sed 's/^/  /'
            echo
            branch=
            ;;
    esac
done
